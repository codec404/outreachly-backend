# Copy this file to local.env and fill in real values.
# local.env is git-ignored — never commit it.

# ── App ─────────────────────────────────────────────────────
# APP_ENV=production   # uncomment in production

# ── Database (app connection) ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chat_db
DB_USER=postgres
DB_PASSWORD=change_me
DB_SSL_MODE=disable  # dev: disable | staging/prod: require or verify-full

# ── Postgres container ───────────────────────────────────────
POSTGRES_DB=chat_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# ── pgAdmin (dev only) ───────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me

# ── Super admin seed (first boot only) ──────────────────────
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@yourdomain.com
SUPER_ADMIN_PASSWORD=change_me_min_8_chars

# ── JWT ──────────────────────────────────────────────────────
# Use a cryptographically random string of at least 32 characters.
JWT_SECRET=change_me_use_a_long_random_secret_min_32_chars
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7
